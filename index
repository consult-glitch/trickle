var state={mode:'slot',sel:'ALL',editing:false,log:[]};
TASKS.forEach(function(t,i){t.id=i+1;t.edited=false;});
var nextId=TASKS.length+1;
var TEAM={};PEOPLE.forEach(function(p){TEAM[p.n]=p.tm;});
var NAMEPAT=new RegExp('('+PEOPLE.map(function(p){return p.n;}).join('|')+')(帶)?','g');

var $=function(id){return document.getElementById(id);};
function esc(s){return String(s).replace(/[&<>"]/g,function(c){return{'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}
function mark(s){
  return esc(s).replace(NAMEPAT,function(m,name){
    var tm=TEAM[name]||'min';
    return '<span class="xl-nm-'+tm+'">'+m+'</span>';
  });
}
function slotById(id){for(var i=0;i<SLOTS.length;i++)if(SLOTS[i].id===id)return SLOTS[i];return null;}
function nowStr(){var d=new Date();return('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2);}
function photoBadge(s){return s.photo?'<span class="xl-badge-photo">📸 '+esc(s.photo)+'</span>':'';}

function renderChips(){
  var h='';
  if(state.mode==='slot'){
    h+='<div class="xl-chip'+(state.sel==='ALL'?' xl-on':'')+'" data-v="ALL">全部</div>';
    SLOTS.forEach(function(s){
      h+='<div class="xl-chip'+(s.photo?' xl-photo-chip':'')+(state.sel===s.id?' xl-on':'')+'" data-v="'+s.id+'">'+(s.photo?'📸':'')+s.t+'</div>';
    });
  }else if(state.mode==='person'){
    PEOPLE.forEach(function(p,i){
      if(i>0&&p.tm==='gov'&&PEOPLE[i-1].tm==='min')h+='<div class="xl-divider">｜衛生局→</div>';
      h+='<div class="xl-chip xl-c-'+p.tm+(state.sel===p.n?' xl-on':'')+'" data-v="'+p.n+'">'+p.n+'</div>';
    });
  }
  $('xlChips').innerHTML=h;
  $('xlChips').style.display=(state.mode==='log')?'none':'flex';
}

function taskRow(t){
  return '<div class="xl-task'+(t.edited?' xl-edited':'')+'"><div class="xl-who"><span class="xl-nm-'+(TEAM[t.p]||'min')+'">'+esc(t.p)+'</span></div>'+
    '<div class="xl-what">'+mark(t.x)+'</div>'+
    '<button class="xl-editbtn" data-edit="'+t.id+'">改</button></div>';
}

function renderMain(){
  var h='';
  if(state.mode==='slot'){
    var list=(state.sel==='ALL')?SLOTS:[slotById(state.sel)];
    list.forEach(function(s){
      var mins=TASKS.filter(function(t){return t.s===s.id&&TEAM[t.p]==='min';});
      var govs=TASKS.filter(function(t){return t.s===s.id&&TEAM[t.p]==='gov';});
      h+='<div class="xl-slot'+(s.photo?' xl-isphoto':'')+'"><div class="xl-slot-h"><span class="xl-time">'+s.t+'</span><span class="xl-title">'+esc(s.title)+'</span>'+photoBadge(s)+'</div>';
      if(mins.length){h+='<div class="xl-sect xl-s-min">敏逆</div>'+mins.map(taskRow).join('');}
      if(govs.length){h+='<div class="xl-sect xl-s-gov">衛生局</div>'+govs.map(taskRow).join('');}
      if(!mins.length&&!govs.length)h+='<div class="xl-empty">此時段無指派</div>';
      if(state.editing)h+='<div class="xl-task"><div class="xl-who"></div><div class="xl-what"></div><button class="xl-editbtn" data-add="'+s.id+'" style="display:block">＋加任務</button></div>';
      if(s.note)h+='<div class="xl-note">📌 '+mark(s.note)+'</div>';
      h+='</div>';
    });
  }else if(state.mode==='person'){
    var p=null;PEOPLE.forEach(function(q){if(q.n===state.sel)p=q;});
    if(!p){h='<div class="xl-empty">請在上方選一個人（黃＝敏逆、藍＝衛生局）</div>';}
    else{
      h+='<div class="xl-pcard"><span class="xl-pname xl-t-'+p.tm+'">'+esc(p.n)+'</span><div class="xl-prole">'+esc(p.r)+'</div>';
      SLOTS.forEach(function(s){
        var mine=TASKS.filter(function(t){return t.s===s.id&&t.p===p.n;});
        var others=[];var seen={};
        TASKS.forEach(function(t){
          if(t.s===s.id&&TEAM[t.p]!==p.tm&&!seen[t.p]){seen[t.p]=1;others.push(t.p);}
        });
        var mateLine=others.length?'<div class="xl-mate">同時段'+(p.tm==='min'?'衛生局':'敏逆')+'：'+others.map(function(n){return '<span class="xl-nm-'+TEAM[n]+'">'+esc(n)+'</span>';}).join('、')+'</div>':'';
        h+='<div class="xl-prow'+(s.photo?' xl-isphoto':'')+'"><div class="xl-ptime">'+s.t+'</div><div class="xl-ptxt">';
        if(mine.length){
          h+=mine.map(function(t){return mark(t.x)+(t.edited?'<span style="color:#c0392b;font-size:11px;font-weight:700">（已更動）</span>':'');}).join('<br>');
        }else{
          h+='<span class="xl-watch"><b>此時段無指派｜可留意：</b>'+esc(s.watch||'支援現場')+'</span>';
        }
        h+='<div class="xl-pslot">'+esc(s.title)+(s.photo?' 📸'+esc(s.photo):'')+'</div>'+mateLine+'</div>';
        if(state.editing&&mine.length)h+='<button class="xl-editbtn" style="display:block" data-edit="'+mine[0].id+'">改</button>';
        h+='</div>';
      });
      h+='</div>';
    }
  }else{
    h+='<div class="xl-log"><h3>變更紀錄（本機，匯出通報後貼群組）</h3>';
    h+=state.log.length?state.log.map(function(l){return '<div class="xl-logitem"><b>'+l.t+'</b>｜'+esc(l.m)+'</div>';}).join(''):'<div class="xl-empty">尚無變更</div>';
    h+='</div>';
  }
  $('xlMain').innerHTML=h;
}

function render(){renderChips();renderMain();
  document.getElementById('xlApp').classList.toggle('xl-editing',state.editing);
  $('xlBtnEdit').textContent=state.editing?'✔ 完成編輯':'✎ 進入編輯';
}

/* ---- 編輯 modal ---- */
function openModal(taskId,addSlot){
  var t=null;if(taskId)TASKS.forEach(function(q){if(q.id===taskId)t=q;});
  var slotOpts=SLOTS.map(function(s){return '<option value="'+s.id+'"'+((t?t.s:addSlot)===s.id?' selected':'')+'>'+s.t+' '+esc(s.title)+'</option>';}).join('');
  var minOpts='',govOpts='';
  PEOPLE.forEach(function(p){
    var o='<option value="'+p.n+'"'+(t&&t.p===p.n?' selected':'')+'>'+p.n+'</option>';
    if(p.tm==='min')minOpts+=o;else govOpts+=o;
  });
  var h='<h3>'+(t?'修改任務':'新增任務')+'</h3>'+
    '<label>時段</label><select id="xlFs">'+slotOpts+'</select>'+
    '<label>負責人</label><select id="xlFp"><optgroup label="敏逆">'+minOpts+'</optgroup><optgroup label="衛生局">'+govOpts+'</optgroup></select>'+
    '<label>工作內容</label><textarea id="xlFx">'+(t?esc(t.x):'')+'</textarea>'+
    '<div class="xl-mbtns">'+(t?'<button class="xl-del" id="xlFdel">刪除</button>':'')+
    '<button id="xlFcancel">取消</button><button class="xl-save" id="xlFsave">儲存</button></div>';
  $('xlModal').innerHTML=h;$('xlMask').classList.add('xl-show');
  $('xlFcancel').onclick=function(){$('xlMask').classList.remove('xl-show');};
  $('xlFsave').onclick=function(){
    var s=$('xlFs').value,pn=$('xlFp').value,x=$('xlFx').value.trim();
    if(!x){$('xlFx').style.borderColor='#c0392b';return;}
    var st=slotById(s);
    if(t){
      var msg='【改】'+st.t+' '+pn+'：'+x+(t.p!==pn?'（原：'+t.p+'）':'');
      t.s=s;t.p=pn;t.x=x;t.edited=true;
      state.log.unshift({t:nowStr(),m:msg});
    }else{
      TASKS.push({id:nextId++,s:s,p:pn,x:x,edited:true});
      state.log.unshift({t:nowStr(),m:'【加】'+st.t+' '+pn+'：'+x});
    }
    $('xlMask').classList.remove('xl-show');render();
  };
  if(t){$('xlFdel').onclick=function(){
    var st=slotById(t.s);
    state.log.unshift({t:nowStr(),m:'【刪】'+st.t+' '+t.p+'：'+t.x});
    TASKS.splice(TASKS.indexOf(t),1);
    $('xlMask').classList.remove('xl-show');render();
  };}
}

/* ---- 通報 / 備份 ---- */
function openReport(){
  var lines=state.log.slice().reverse().map(function(l){return l.t+' '+l.m;});
  var txt=lines.length?('📢 細流異動通報（'+nowStr()+' 發布）\n'+lines.join('\n')+'\n—— 以此通報為準，收到請回 1'):'目前沒有任何變更。';
  var h='<h3>變更通報（複製貼到工作群）</h3><textarea class="xl-io" id="xlRtxt">'+esc(txt)+'</textarea>'+
    '<div class="xl-mbtns"><button id="xlFcancel">關閉</button><button class="xl-save" id="xlRcopy">複製文字</button></div>'+
    '<div class="xl-hint">同步原則：只有一台裝置（副指揮）能改，其他人只收群組通報。改完立刻發通報＋對講機廣播，就不會版本不同步。</div>';
  $('xlModal').innerHTML=h;$('xlMask').classList.add('xl-show');
  $('xlFcancel').onclick=function(){$('xlMask').classList.remove('xl-show');};
  $('xlRcopy').onclick=function(){
    var ta=$('xlRtxt');ta.select();ta.setSelectionRange(0,999999);
    try{document.execCommand('copy');$('xlRcopy').textContent='已複製 ✔';}catch(e){$('xlRcopy').textContent='請長按手動複製';}
  };
}
function openIO(){
  var data=JSON.stringify({tasks:TASKS,log:state.log});
  var h='<h3>備份 / 還原</h3><label>目前資料（複製保存；換裝置時貼回並按還原）</label>'+
    '<textarea class="xl-io" id="xlIOtxt">'+esc(data)+'</textarea>'+
    '<div class="xl-mbtns"><button id="xlFcancel">關閉</button><button class="xl-save" id="xlIOload">用上面內容還原</button></div>'+
    '<div class="xl-hint">注意：關閉或重新整理頁面後，未備份的變更會消失（本頁刻意不用雲端或本機儲存，避免多裝置版本混亂）。重大改動請先按「產生變更通報」發到群組。</div>';
  $('xlModal').innerHTML=h;$('xlMask').classList.add('xl-show');
  $('xlFcancel').onclick=function(){$('xlMask').classList.remove('xl-show');};
  $('xlIOload').onclick=function(){
    try{
      var d=JSON.parse($('xlIOtxt').value);
      if(d&&d.tasks){TASKS.length=0;d.tasks.forEach(function(t){TASKS.push(t);});
        state.log=d.log||[];nextId=TASKS.reduce(function(m,t){return Math.max(m,t.id||0);},0)+1;
        $('xlMask').classList.remove('xl-show');render();}
    }catch(e){$('xlIOload').textContent='格式錯誤，請確認 JSON';}
  };
}

/* ---- 事件 ---- */
$('xlModeSlot').onclick=function(){state.mode='slot';state.sel='ALL';setMode();};
$('xlModePerson').onclick=function(){state.mode='person';state.sel=PEOPLE[0].n;setMode();};
$('xlModeLog').onclick=function(){state.mode='log';setMode();};
function setMode(){
  ['xlModeSlot','xlModePerson','xlModeLog'].forEach(function(id){$(id).classList.remove('xl-on');});
  $(state.mode==='slot'?'xlModeSlot':state.mode==='person'?'xlModePerson':'xlModeLog').classList.add('xl-on');
  render();
}
$('xlChips').onclick=function(e){
  var el=e.target.closest?e.target.closest('[data-v]'):e.target;
  var v=el&&el.getAttribute?el.getAttribute('data-v'):null;
  if(v){state.sel=v;render();}
};
$('xlMain').onclick=function(e){
  var ed=e.target.getAttribute&&e.target.getAttribute('data-edit');
  var ad=e.target.getAttribute&&e.target.getAttribute('data-add');
  if(ed)openModal(parseInt(ed,10),null);
  else if(ad)openModal(null,ad);
};
$('xlBtnEdit').onclick=function(){state.editing=!state.editing;render();};
$('xlBtnReport').onclick=openReport;
$('xlBtnIO').onclick=openIO;
$('xlMask').onclick=function(e){if(e.target===$('xlMask'))$('xlMask').classList.remove('xl-show');};

render();
})();
</script>
</body>
</html>
